## Data Loading

```python
import pandas as pd
import numpy as np

# Load the dataset
file_path = 'path/to/superstore_sales.csv'
sales_data = pd.read_csv(file_path)
print(sales_data.head())
```

## Exploratory Data Analysis (EDA)

```python
import seaborn as sns
import matplotlib.pyplot as plt

# Basic information of the dataset
print(sales_data.info())
print(sales_data.describe())

# Visualize data distribution
sns.histplot(sales_data['Sales'])
plt.title('Sales Distribution')
plt.show()

# Correlation matrix
correlation = sales_data.corr()
sns.heatmap(correlation, annot=True)
plt.title('Correlation Heatmap')
plt.show()
```

## Data Preprocessing

```python
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OneHotEncoder, StandardScaler

# Handling categorical variables
categorical_cols = sales_data.select_dtypes(include=['object']).columns
encoder = OneHotEncoder(drop='first', sparse=False)
encoded_data = encoder.fit_transform(sales_data[categorical_cols])
encoded_df = pd.DataFrame(encoded_data, columns=encoder.get_feature_names_out(categorical_cols))

# Combining encoded columns with the numeric data
numeric_data = sales_data.select_dtypes(exclude=['object'])
final_data = pd.concat([numeric_data.reset_index(drop=True), encoded_df.reset_index(drop=True)], axis=1)

# Train-test split
X = final_data.drop('Sales', axis=1)
Y = final_data['Sales']
X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.2, random_state=0)
```

## Model Training

### Linear Regression
```python
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error

# Fit the model
lm_model = LinearRegression()
lm_model.fit(X_train, Y_train)

# Predictions
lm_predictions = lm_model.predict(X_test)

# Performance metrics
lm_mse = mean_squared_error(Y_test, lm_predictions)
print(f'Linear Regression MSE: {lm_mse}')
```

### Random Forest
```python
from sklearn.ensemble import RandomForestRegressor

# Fit the model
rf_model = RandomForestRegressor(random_state=0)
rf_model.fit(X_train, Y_train)

# Predictions
rf_predictions = rf_model.predict(X_test)

# Performance metrics
rf_mse = mean_squared_error(Y_test, rf_predictions)
print(f'Random Forest MSE: {rf_mse}')
```

## Hyperparameter Tuning

```python
from sklearn.model_selection import GridSearchCV

# Hyperparameter tuning for Random Forest
param_grid = {'n_estimators': [50, 100], 'max_depth': [None, 10, 20]}
grid_search = GridSearchCV(RandomForestRegressor(random_state=0), param_grid, cv=5)
grid_search.fit(X_train, Y_train)

print(f'Best parameters: {grid_search.best_params_}')
```

## Model Comparison

```python
print(f'Linear Regression MSE: {lm_mse}')
print(f'Random Forest MSE with Tuning: {mean_squared_error(Y_test, grid_search.best_estimator_.predict(X_test))}')
```

## Feature Importance

```python
# Feature importance from Random Forest
importances = rf_model.feature_importances_
indices = np.argsort(importances)[::-1]

# Print the feature ranking
for f in range(X.shape[1]):
    print(f'{f + 1}. Feature {X.columns[indices[f]]} - Importance: {importances[indices[f]]}')
```

## Residual Analysis

```python
residuals = Y_test - lm_predictions
sns.histplot(residuals, bins=30)
plt.title('Residuals Distribution')
plt.show()
```

